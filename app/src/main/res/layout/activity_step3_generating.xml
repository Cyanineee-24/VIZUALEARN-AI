<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:id="@+id/relativelayoutStickyHeader"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageviewBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_back"
                android:padding="6dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#FFFFFF" />

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:orientation="vertical">
                <TextView android:id="@+id/textviewHeaderTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif-black" android:text="Generating" android:textColor="#1A1A1A" android:textSize="20sp" />
                <TextView android:id="@+id/textviewStepNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Step 3 of 4" android:textColor="#A0A0A0" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutUniversalFooter"
        android:layout_below="@+id/relativelayoutStickyHeader"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="100dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_banner_purple" android:padding="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_folder_orange" />
                <TextView android:id="@+id/textviewSavingInto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Saving into: Biology" android:textColor="#7E57C2" android:textStyle="bold" android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageviewGeneratingIcon"
                    android:layout_width="120dp"
                    android:padding="6dp"
                    android:background="@drawable/bg_circle_light_purple"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_generating_brain" />

                <TextView android:id="@+id/textviewGeneratingTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:fontFamily="sans-serif-black" android:text="Generating your mind map...." android:textColor="#1A1A1A" android:textSize="18sp" />

                <TextView android:id="@+id/textviewGeneratingSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Gemini is reading your notes and crafting your flash cards" android:textColor="#A0A0A0" android:textSize="12sp" android:gravity="center"/>
            </LinearLayout>

            <TextView
                android:id="@+id/textviewContinue"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="100dp"
                android:background="@drawable/bg_btn_disabled"
                android:gravity="center"
                android:text="Continue"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:clickable="false"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_universal_footer" android:id="@+id/layoutUniversalFooter" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_alignParentBottom="true" />
</RelativeLayout>