<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- ================= STICKY HEADER ================= -->
    <LinearLayout
        android:id="@+id/linearlayoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/textviewPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="Progress"
            android:textColor="#1A1A1A"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/textviewPageSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Stay consistent. Track your mastery."
            android:textColor="#A0A0A0"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ================= SCROLLABLE CONTENT ================= -->
    <ScrollView
        android:id="@+id/scrollviewMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/universal_footer"
        android:layout_below="@+id/linearlayoutHeader"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/linearlayoutContentBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <!-- ================= CONSISTENCY SECTION ================= -->
            <TextView
                android:id="@+id/textviewConsistencyLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="CONSISTENCY"
                android:textColor="#A0A0A0"
                android:textSize="10sp" />

            <!-- Dark Streak Card -->
            <LinearLayout
                android:id="@+id/linearlayoutStreakCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_streak_card_dark"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Top Row: Current & Best -->
                <RelativeLayout
                    android:id="@+id/relativelayoutStreakTop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imageviewMainFlame"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ft_streak" /> <!-- Replace with your flame icon -->

                    <LinearLayout
                        android:id="@+id/linearlayoutCurrentStreakTexts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp"
                        android:layout_toEndOf="@id/imageviewMainFlame"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textviewCurrentStreakLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current streak"
                            android:textColor="#A0A0A0"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:id="@+id/linearlayoutStreakNumbers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="bottom"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/textviewStreakCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-black"
                                android:includeFontPadding="false"
                                android:text="14"
                                android:textColor="#FFFFFF"
                                android:textSize="32sp" />

                            <TextView
                                android:id="@+id/textviewStreakDaysText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="4dp"
                                android:text="days"
                                android:textColor="#A0A0A0"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Best Streak Box -->
                    <LinearLayout
                        android:id="@+id/linearlayoutBestStreakBox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_streak_best_box"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/textviewBestLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best"
                            android:textColor="#A0A0A0"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/textviewBestNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="14"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />
                    </LinearLayout>
                </RelativeLayout>

                <!-- Weekly Pills Row -->
                <!-- Weekly Pills Row -->
                <LinearLayout
                    android:id="@+id/linearlayoutWeekDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Day 1 -->
                    <LinearLayout android:id="@+id/linearlayoutDayMon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameMon" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDayMon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Mon" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 2 -->
                    <LinearLayout android:id="@+id/linearlayoutDayTue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameTue" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDayTue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Tue" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 3 -->
                    <LinearLayout android:id="@+id/linearlayoutDayWed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameWed" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDayWed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Wed" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 4 -->
                    <LinearLayout android:id="@+id/linearlayoutDayThu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameThu" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDayThu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Thu" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 5 -->
                    <LinearLayout android:id="@+id/linearlayoutDayFri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameFri" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDayFri" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Fri" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 6 -->
                    <LinearLayout android:id="@+id/linearlayoutDaySat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameSat" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDaySat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sat" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Day 7 -->
                    <LinearLayout android:id="@+id/linearlayoutDaySun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <ImageView android:id="@+id/imageviewFlameSun" android:layout_width="32dp" android:layout_height="36dp" android:background="@drawable/bg_streak_best_box" android:padding="6dp" />
                        <TextView android:id="@+id/textviewDaySun" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sun" android:textColor="#555566" android:textSize="9sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Milestone Bar -->
                <RelativeLayout
                    android:id="@+id/relativelayoutMilestoneTexts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp">

                    <TextView
                        android:id="@+id/textviewNextMilestoneLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next milestone"
                        android:textColor="#A0A0A0"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/textviewMilestoneGoalText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="21 days — 7 to go"
                        android:textColor="#FF9800"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Progress Bar Layout Trick -->
                <LinearLayout
                    android:id="@+id/linearlayoutMilestoneBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_streak_best_box"
                    android:orientation="horizontal"
                    android:weightSum="100">

                    <!-- Fill -->
                    <View
                        android:id="@+id/viewMilestoneFill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="66"
                        android:background="#FF9800" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textviewPersonalBestMotivator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:drawablePadding="8dp"
                    android:text="🏆 Personal best — keep it going!"
                    android:textColor="#FF9800"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Small Stats Row -->
            <LinearLayout
                android:id="@+id/linearlayoutStatsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Total Days -->
                <LinearLayout android:id="@+id/linearlayoutStatTotal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_outline" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                    <ImageView android:id="@+id/imageviewIconTotal" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/calendar" />
                    <TextView android:id="@+id/textviewStatTotalNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="sans-serif-black" android:text="38" android:textColor="#1A1A1A" android:textSize="18sp" />
                    <TextView android:id="@+id/textviewStatTotalLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Days" android:textColor="#A0A0A0" android:textSize="10sp" />
                </LinearLayout>

                <!-- This Month -->
                <LinearLayout android:id="@+id/linearlayoutStatMonth" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:background="@drawable/bg_outline" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                    <ImageView android:id="@+id/imageviewIconMonth" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/calendar" />
                    <TextView android:id="@+id/textviewStatMonthNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="sans-serif-black" android:text="14" android:textColor="#1A1A1A" android:textSize="18sp" />
                    <TextView android:id="@+id/textviewStatMonthLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="This Month" android:textColor="#A0A0A0" android:textSize="10sp" />
                </LinearLayout>

                <!-- Missed Days -->
                <LinearLayout android:id="@+id/linearlayoutStatMissed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_outline" android:gravity="center" android:orientation="vertical" android:padding="12dp">
                    <ImageView android:id="@+id/imageviewIconMissed" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/calendar" />
                    <TextView android:id="@+id/textviewStatMissedNumber" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="sans-serif-black" android:text="3" android:textColor="#1A1A1A" android:textSize="18sp" />
                    <TextView android:id="@+id/textviewStatMissedLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Missed Days" android:textColor="#A0A0A0" android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ================= MASTERY RATE SECTION ================= -->
            <TextView
                android:id="@+id/textviewMasteryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-black"
                android:text="MASTERY RATE"
                android:textColor="#A0A0A0"
                android:textSize="10sp" />

            <!-- Overall Mastery Card -->
            <LinearLayout
                android:id="@+id/linearlayoutOverallMasteryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="20dp">

                <!-- Circular Progress Ring (Faked with layered drawable for static UI) -->
                <RelativeLayout
                    android:id="@+id/relativelayoutMasteryRingContainer"
                    android:layout_width="64dp"
                    android:layout_height="64dp">

                    <ProgressBar
                        android:id="@+id/progressbarMastery"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="66"
                        android:progressDrawable="@drawable/bg_mastery_ring" />

                    <TextView
                        android:id="@+id/textviewMasteryPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="sans-serif-black"
                        android:text="66%"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/linearlayoutMasteryTexts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textviewMasteryTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Overall Mastery"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textviewMasteryDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cards marked 'Got it!' vs\ntotal cards reviewed across all sets"
                        android:textColor="#A0A0A0"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- By Subject Card -->
            <LinearLayout
                android:id="@+id/linearlayoutBySubjectCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_outline"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/textviewBySubjectTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="By Subject"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp" />

<!--                &lt;!&ndash; Subject 1: Biology &ndash;&gt;-->
<!--                <RelativeLayout android:id="@+id/relativelayoutSubBio" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">-->
