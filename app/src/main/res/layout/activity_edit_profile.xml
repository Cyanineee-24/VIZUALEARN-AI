<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ================= STICKY HEADER ================= -->
    <RelativeLayout
        android:id="@+id/relativelayoutHeader"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageviewBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_back"
                android:padding="6dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/textviewHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-black"
                android:text="Edit Profile"
                android:textColor="#1A1A1A"
                android:textSize="20sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ================= SCROLLABLE CONTENT ================= -->
    <ScrollView
        android:id="@+id/scrollviewMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/universal_footer"
        android:layout_below="@+id/relativelayoutHeader"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/linearlayoutContentBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="100dp"> <!-- Extra padding to clear footer -->

            <RelativeLayout
                android:id="@+id/relativelayoutProfilePicContainer"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp">

                <!-- Your custom double CardView centered in the box -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardviewOuterRing"
                    android:layout_width="104dp"
                    android:layout_height="104dp"
                    android:layout_centerInParent="true"
                    app:cardCornerRadius="52dp"
                    app:cardBackgroundColor="#4C68FF"
                    app:cardElevation="0dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardviewInnerPic"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/imageviewProfilePic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profilepic" />
                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>

                <!-- Edit Pencil Badge overlapping the bottom right -->
                <ImageView
                    android:id="@+id/imageviewEditBadge"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginBottom="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_edit_badge_squircle"
                    android:padding="6dp"
                    android:elevation="4dp"
                    android:src="@drawable/ic_pencil" />
            </RelativeLayout>

            <!-- Change Photo Text Button -->
            <TextView
                android:id="@+id/textviewChangePhotoLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-black"
                android:text="Change Profile Photo"
                android:textColor="#36168F"
                android:textSize="14sp" />

            <!-- Standard Labeled Fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <!-- First Name (Interactive) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="First Name"
                        android:textColor="#1A1A1A"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/edittextFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_outline"
                        android:fontFamily="sans-serif"
                        android:hint="Enter first name"
                        android:inputType="textPersonName"
                        android:padding="14dp"
                        android:singleLine="true"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#B0B0B0"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="16dp"
                    android:layout_height="0dp" />

                <!-- Last Name (Interactive) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Last Name"
                        android:textColor="#1A1A1A"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/edittextLastName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_outline"
                        android:fontFamily="sans-serif"
                        android:hint="Enter last name"
                        android:inputType="textPersonName"
                        android:padding="14dp"
                        android:singleLine="true"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#B0B0B0"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Email Address (Interactive) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Email Address"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edittextEmailAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_outline"
                android:fontFamily="sans-serif"
                android:hint="Enter email address"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#B0B0B0"
                android:textSize="14sp" />

            <!-- School / University (Interactive) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="School / University"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edittextSchoolUniversity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_outline"
                android:fontFamily="sans-serif"
                android:hint="e.g. &quot;Stanford University&quot;"
                android:inputType="textCapWords"
                android:padding="14dp"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#B0B0B0"
                android:textSize="14sp" />

            <!-- Field of Study (Interactive) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Field of Study"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edittextFieldOfStudy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_outline"
                android:fontFamily="sans-serif"
                android:hint="e.g. &quot;Computer Science&quot;"
                android:inputType="textCapWords"
                android:padding="14dp"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#B0B0B0"
                android:textSize="14sp" />

            <!-- Address (Interactive) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="sans-serif-black"
                android:text="Address"
                android:textColor="#1A1A1A"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/edittextAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_outline"
                android:fontFamily="sans-serif"
                android:hint="Enter address"
                android:inputType="textPostalAddress"
                android:padding="14dp"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#B0B0B0"
                android:textSize="14sp" />

            <!-- Action Buttons -->
            <!-- Save Changes Button (Recycling bg_btn_save logic) (Interactive) -->
            <TextView
                android:id="@+id/textviewSaveChangesBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_btn_save"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Save Changes"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Cancel Button (Interactive) -->
            <TextView
                android:id="@+id/textviewCancelLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Cancel"
                android:textColor="#E53935"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Info Banner (Recycling bg_info_banner logic) -->
            <LinearLayout
                android:id="@+id/linearlayoutInfoBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_info_banner"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imageviewInfoLightbulb"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_lightbulb_outline" />

                <TextView
                    android:id="@+id/textviewInfoBannerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="4dp"
                    android:text="Once your set is created, you'll add flash cards and ind maps inside it – one by one, as many as you need."
                    android:textColor="#7E57C2"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ================= UNIVERSAL FOOTER ================= -->
    <include
        layout="@layout/layout_universal_footer"
        android:id="@+id/universal_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>