<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- ================= STICKY HEADER ================= -->
    <RelativeLayout
        android:id="@+id/relativelayoutStickyHeader"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageviewBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_back"
                android:padding="6dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textviewMapTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="#1A1A1A"
                    android:textSize="20sp"
                    tools:text="Cardiovascular System" />

                <TextView
                    android:id="@+id/textviewMapSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp"
                    tools:text="Biology • 8 nodes • AI generated" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

    <!-- ================= UNIVERSAL FOOTER ================= -->
    <include layout="@layout/layout_universal_footer"
        android:id="@+id/universal_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

    <!-- ================= MAIN CONTENT AREA ================= -->
    <!-- Sits between the header and footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/relativelayoutStickyHeader"
        android:layout_above="@id/universal_footer"
        android:orientation="vertical">

        <!-- THE CANVAS (Takes up all remaining vertical space) -->
        <WebView
            android:id="@+id/webViewCytoscape"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F5F5F5"/>

        <!-- CONTROLS PANEL (Regenerate, Export, Prompt) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


                <View android:layout_width="12dp" android:layout_height="0dp" />

                <LinearLayout
                    android:id="@+id/linearlayoutBtnExport"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_generate_purple"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_export" app:tint="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Export to Images" android:textColor="#FFFFFF" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- NODE DETAILS PANEL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5F5"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/linearlayoutNodeDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NODE DESCRIPTION"
                    android:textColor="#A0A0A0"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/textviewNodeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tap a node to begin"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/textviewNodeDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="The node's detailed explanation will appear here."
                    android:textColor="#A0A0A0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>