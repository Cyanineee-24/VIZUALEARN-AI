<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- ================= STICKY HEADER (Unchanged) ================= -->
    <RelativeLayout
        android:id="@+id/relativelayoutStickyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingTop="10dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/linearlayoutHeaderTitles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageviewBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_back"
                android:padding="8dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:id="@+id/linearlayoutTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textviewSetTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Anatomy and Physiology"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/textviewSetSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 Sets Created"
                    android:textColor="#A0A0A0"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/imageviewEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="0dp"
            android:src="@drawable/pencil" />
    </RelativeLayout>

    <!-- ================= SCROLLABLE CONTENT ================= -->
    <ScrollView
        android:id="@+id/scrollviewMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/universal_footer"
        android:layout_below="@+id/relativelayoutStickyHeader"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/linearlayoutContentBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="40dp">

            <!-- ================= FLASH CARD SECTION ================= -->
            <TextView
                android:id="@+id/textviewFlashCardSetsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Flash Card Sets"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />

            <!-- UPGRADED: RecyclerView instead of empty LinearLayout -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFlashcardDecks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_deck_card" />

            <!-- Add Flash Cards Dashed Button (Fixed ID) -->
            <LinearLayout
                android:id="@+id/linearlayoutAddNewFlashCardSetButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_btn_continue_orange">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sparkles"
                    app:tint="#FFD700"
                    android:layout_gravity="center"/>
                <TextView
                    android:id="@+id/textviewContinue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginStart="3dp"
                    android:text="Add new Flash Card Set"
                    android:textColor="#FFFFFF" />
            </LinearLayout>


            <!-- ================= MIND MAPS SECTION ================= -->

            <TextView
                android:id="@+id/textviewMindMapsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-black"
                android:text="Mind Maps"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />

            <!-- UPGRADED: RecyclerView instead of empty LinearLayout -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMindMaps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_deck_card" />

            <!-- Add Mind Map Dashed Button (Fixed ID) -->
            <LinearLayout
                android:id="@+id/linearlayoutAddNewMindMapButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_generate_purple"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sparkles"
                    app:tint="#FFD700" />
                <TextView
                    android:id="@+id/textviewAddNewMindMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="Add new Mind Map"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ================= UNIVERSAL FOOTER (Unchanged) ================= -->
    <include
        layout="@layout/layout_universal_footer"
        android:id="@+id/universal_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>